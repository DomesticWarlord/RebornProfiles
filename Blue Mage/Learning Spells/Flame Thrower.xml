	<!ENTITY Shortcut "2000700">

	<!ENTITY FirstBoss "2548"> <!-- Illuminati Commander -->
	<!ENTITY Boss1SubZone "687">
	<!ENTITY SecondBoss "2549"> <!-- Magitek Vangob G-III  -->
