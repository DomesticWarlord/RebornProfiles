<Profile>
	<Name>Brayflox's Longstop (Hard)</Name>
	<BehaviorDirectory></BehaviorDirectory>
	<Order>

		<!-- [Unlock Brayflox's Longstop (Hard)] Curds and Slay -->
		<If Condition="not IsQuestCompleted(66947)">
			<If Condition="not HasQuest(66947)">
				<GetTo ZoneId="156" XYZ="32.51, 21.27503, -636.2501" />
				<If Condition="IsQuestAcceptQualified(66947)">
					<PickupQuest QuestId="66947" NpcId="1006975" XYZ="32.82214, 21.25273, -635.462" />
				</If>
			</If>
			<If Condition="GetQuestStep(66947) == 1">
				<GetTo ZoneId="137" XYZ="559.1483, 20.75329, 455.952" />
				<TalkTo NpcId="1006266" XYZ="560.3571, 20.75329, 455.8937" QuestId="66947" StepId="1" />
			</If>
			<If Condition="GetQuestStep(66947) == 255">
				<LisbethTravel Area="Eastern La Noscea (Raincatcher Gully)" Position="-331.2567, 69.03585, 155.8954" />
				<TurnIn QuestId="66947" NpcId="1006268" XYZ="-334.6151, 69.69995, 153.7957" />
			</If>
		</If>

		<While condition="not DutyManager.InInstance and not IsOnMap(&ZoneId;)">
			<StopBusy />
			<If condition="&QueueType; == 0">
				<JoinDuty DutyId="&DutyId;" />
			</If>
			<If condition="&QueueType; == 1">
				<JoinSupportDuty DutyId="&DutyId;" />
			</If>
		</While>

		<While condition="DutyManager.InInstance and IsOnMap(&ZoneId;)">

			<!-- Shortcut available -->
			<If condition="IsNearShortcut(&Shortcut;)">
				<UseShortcut NpcId="&Shortcut;" Distance="20" />
			</If>

			<!-- Farm first Tiny Key -->
			<If Condition="GetInstanceTodo(0) == 0 and GetInstanceTodo(1) == 0">
				<Log Message="Farming first Tiny Key" />
				<DisablePlugin name="SideStep" />
				<While condition="GetInstanceTodo(0) == 0">
					<MoveTo XYZ="-86.06763, -2.381622, 9.162037" />
					<While condition="not GameObjectManager.GetObjectByNPCId(2002325)">
						<MoveTo XYZ="-8.675864, -0.7706152, 0.8579024" />
					</While>
					<Grind GrindRef="FarmTinyKey" While="not GameObjectManager.GetObjectByNPCId(2002325) and GetInstanceTodo(0) == 0" />
					<While condition="GameObjectManager.GetObjectByNPCId(2002325) and GameObjectManager.GetObjectByNPCId(2002325).IsVisible">
						<UseObject NpcIds="2002325" radius="200" XYZ="-7.703425,-1.383872,-2.724141" condition="GetInstanceTodo(0) == 0" UseTimes="1" />
						<WaitTimer WaitTime="1" />
					</While>
				</While>
				<EnablePlugin name="SideStep" />
			</If>

			<!-- Clear Runstop Frontblock 0/1 -->
			<If Condition="GetInstanceTodo(1) == 0 and GetInstanceTodo(0) == 1">
				<Log Message="Clear Runstop Frontblock 0/1" />
				<MoveTo XYZ="105.253, -0.1222783, 12.77754" distance="2" /> <!-- Move to Headgate -->
				<While condition="GameObjectManager.GetObjectByNPCId(2002182).IsTargetable">
					<UseTransport NpcId="2002182" InteractDistance="2.0" XYZ="105.9128, 1.724182, 11.42896" />
				</While>
				<MoveTo XYZ="113.9325, -2.48531, -17.92782" /> <!-- Move to first boss -->
				<Grind GrindRef="BrayfloxFirstBoss" While="GetInstanceTodo(1) == 0" /> <!-- Fight First Boss -->
<!-- 				<If Condition="&openchest; == 1">
					<MoveTo XYZ="110.6127,-1.571716,-49.69867" />
					<LLOpenChest />
				</If> -->
			</If>

			<!-- Liberate captured goblins 0/3 -->
			<If Condition="GetInstanceTodo(2) &lt; 3 and GetInstanceTodo(1) == 1">
				<Log Message="Liberate captured goblins 0/3" />
				<NoCombatMoveTo XYZ="54.05124, 5.563286, -99.80206" />
				<Grind GrindRef="CapturedGoblins" While="GetInstanceTodo(2) &lt; 3" /> <!-- Liberate Captured Goblins -->
				<MoveTo XYZ="44.75682, 7.015042, -128.6179" /> <!-- Move to cave entrance -->
				<If condition="GameObjectManager.GetObjectByNPCId(1300)">
					<WaitWhile condition="GameObjectManager.GetObjectByNPCId(1300)" />
				</If>
				<LLChangeZone Heading="3.190046" />
			</If>

			<!-- Clear Brayflox's Drossdump 0/1 -->
			<If Condition="GetInstanceTodo(3) == 0 and GetInstanceTodo(2) == 3">
				<Log Message="Clear Brayflox's Drossdump 0/1" />
				<If condition="IsOnSubMap(683)">
					<WaitWhile condition="GameObjectManager.GetObjectByNPCId(1300)" />
					<LLChangeZone Heading="3.190046" />
				</If>
				<Grind GrindRef="BrayfloxSecondBoss" While="GetInstanceTodo(3) == 0" /> <!-- Kill second boss -->
<!-- 				<If Condition="&openchest; == 1">
					<MoveTo XYZ="-24.0025,25.5282,-176.4706" />
					<LLOpenChest />
				</If> -->
			</If>

			<!-- Open Swiftmake Checkgates 0/2 -->
			<If Condition="GetInstanceTodo(4) == 0 and GetInstanceTodo(3) == 1">
				<Log Message="Open Swiftmake Checkgates 0/2" />
<!-- 				<If Condition="&openchest; == 1 and AnyChestsToOpen()">
					<MoveTo XYZ="-42.37433,18.47864,-119.0662" />
					<LLOpenChest />
				</If> -->
				<While condition="GetInstanceTodo(0) == 0 and GetInstanceTodo(4) == 0">
					<Grind GrindRef="TinyKeyFarm2" While="not GameObjectManager.GetObjectByNPCId(2002642) and GetInstanceTodo(4) == 0" />
					<WaitWhile condition="GameObjectManager.GetObjectByNPCId(2002642) and not GameObjectManager.GetObjectByNPCId(2002642).IsVisible" />
					<While condition="GameObjectManager.GetObjectByNPCId(2002642) and GameObjectManager.GetObjectByNPCId(2002642).IsVisible">
						<UseObject NpcIds="2002642" radius="200" XYZ="-88.23793,13.14307,-122.5465" condition="GetInstanceTodo(0) == 0" UseTimes="1" />
						<WaitTimer WaitTime="1" />
					</While>
				</While>
				<While condition="GameObjectManager.GetObjectByNPCId(2002184).IsTargetable">
					<UseTransport NpcId="2002184" InteractDistance="2.0" XYZ="-95.26472, 12.88843, -122.5933" />
				</While>
			</If>

			<!-- Open Swiftmake Checkgates 1/2 -->
			<If Condition="GetInstanceTodo(4) == 1">
				<Log Message="Open Swiftmake Checkgates 1/2" />
				<While condition="GetInstanceTodo(4) == 1 and GetInstanceTodo(0) == 0">
					<Grind GrindRef="TinyKeyFarm3" While="not GameObjectManager.GetObjectByNPCId(2002644) and GetInstanceTodo(4) == 1" />
					<WaitWhile condition="GameObjectManager.GetObjectByNPCId(2002644) and not GameObjectManager.GetObjectByNPCId(2002644).IsVisible" />
					<While condition="GameObjectManager.GetObjectByNPCId(2002644) and GameObjectManager.GetObjectByNPCId(2002644).IsVisible">
						<UseObject InCombat="true" NpcIds="2002644" radius="200" XYZ="-93.87576,20.48067,-173.7249" condition="GetInstanceTodo(0) == 0" UseTimes="1" />
						<WaitTimer WaitTime="1" />
					</While>
				</While>
				<While condition="GameObjectManager.GetObjectByNPCId(2002884).IsTargetable">
					<UseTransport NpcId="2002884" InteractDistance="2.0" XYZ="-102.6475, 21.0116, -187.3655" />
				</While>
			</If>

			<!-- Defeat the gobmachine G-VI 0/1 -->
			<If Condition="GetInstanceTodo(5) == 0 and GetInstanceTodo(4) == 2">
				<Log Message="Defeat the gobmachine G-VI 0/1" />
				<MoveTo XYZ="-44.58178, 34.72327, -235.4707" /> <!-- Move to final boss -->
				<Grind GrindRef="BrayfloxFinalBoss" While="GetInstanceTodo(5) == 0" /> <!-- Kill second boss -->
<!-- 				<If Condition="&openchest; == 1">
					<MoveTo XYZ="-29.40417,35.20251,-229.0837" />
					<LLOpenChest />
				</If> -->
			</If>

			<While condition="DutyManager.InInstance and IsDutyEnded()">
				<WaitTimer WaitTime="3" />
				<LLLeaveDuty />
			</While>

		</While>

		<LastProfile />

	</Order>
	<GrindAreas>
		<GrindArea name="FarmTinyKey">
			<Hotspots>
				<HotSpot XYZ="-3.046232, -2.381622, -8.19621" Radius="20" />
				<HotSpot XYZ="-41.62485, -2.381622, 54.28693" Radius="20" />
				<HotSpot XYZ="-80.95903, -2.381622, 10.26071" Radius="20" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2660" Weight="1" /> <!-- Illuminati Soldier -->
			</TargetMobs>
		</GrindArea>
		<GrindArea name="BrayfloxFirstBoss">
			<Hotspots>
				<Hotspot Radius="200" XYZ="111.4667,-2.443486,-40.1763" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Name="Illuminati Commander" Id="2548" Weight="1" />
			</TargetMobs>
		</GrindArea>
		<GrindArea name="BrayfloxSecondBoss">
			<Hotspots>
				<Hotspot Radius="200" XYZ="-22.56818,25.52351,-174.3038" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2549" Weight="1" />
			</TargetMobs>
		</GrindArea>
		<GrindArea name="TinyKeyFarm2">
			<Hotspots>
				<Hotspot Radius="30" XYZ="-85.80434, 13.88431, -125.8757" name="Name" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2661" Weight="1" /> <!-- Illuminati Marksman -->
			</TargetMobs>
		</GrindArea>
		<GrindArea name="TinyKeyFarm3">
			<Hotspots>
				<Hotspot Radius="30" XYZ="-100.709, 20.73654, -178.6892" name="Name" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2661" Weight="1" /> <!-- Illuminati Marksman -->
				<TargetMob Id="2660" Weight="1" /> <!-- Illuminati Soldier -->
			</TargetMobs>
		</GrindArea>
		<GrindArea name="CapturedGoblins">
			<Hotspots>
				<Hotspot Radius="40" XYZ="91.8576, 4.53233, -104.8914" name="FirstCage" />
				<Hotspot Radius="40" XYZ="34.06355, 7.038593, -85.85194" name="SecondCage" />
				<Hotspot Radius="40" XYZ="28.31378, 6.905986, -118.8425" name="ThirdCage" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2660" Weight="1" /> <!-- Illuminati Soldier -->
				<TargetMob Id="2656" Weight="1" /> <!-- Illuminati Glider -->
				<TargetMob Id="2659" Weight="1"/> <!-- Eoraptor -->
			</TargetMobs>
		</GrindArea>
		<GrindArea name="BrayfloxFinalBoss">
			<Hotspots>
				<Hotspot Radius="200" XYZ="-26.09322,35.28735,-228.3997" />
			</Hotspots>
			<TargetMobs>
				<TargetMob Id="2547" Weight="1" />
			</TargetMobs>
		</GrindArea>
	</GrindAreas>
	<CodeChunks> </CodeChunks>
</Profile>
