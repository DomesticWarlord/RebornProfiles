<!-- User Configuration -->
<!DOCTYPE Profile [
	<!-- ONLY SET ONE ZONE TO True! -->

	<!ENTITY LowerLaNoscea "False"> <!-- Farm chunk of brickman in Lower La Noscea. -->
	<!ENTITY UpperLaNoscea "False"> <!-- Farm chunk of brickman in Upper La Noscea. -->
	<!ENTITY CentralShroud "False"> <!-- Farm chunk of brickman in Central Shroud. -->
	<!ENTITY NorthShroud "True"> <!-- Farm chunk of brickman in North Shroud. -->
	<!ENTITY CentralThanalan "False"> <!-- Farm chunk of brickman in Central Thanalan. -->

	<!-- Log Colors -->

	<!ENTITY LogColor "#66FF66"> <!-- Normal -->
	<!ENTITY LogColorAck "#FF0000"> <!-- Warnings -->

	<!-- 660 - Brick by Brick -->
	<!-- 661 - Brick by Stone Brick -->
	<!-- 666 - Brick by Brick -->
	<!-- 667 - Brick by Stone Brick -->
	<!-- 668 - Brick by Brick -->
	<!-- 669 - Brick by Stone Brick -->
	<!-- 670 - Brick by Brick -->
	<!-- 671 - Brick by Gold Brick -->
	<!-- 672 - Brick by Brick -->
	<!-- 673 -Brick by Stone Brick -->
	<!-- 674 - Brick by Brick -->
	<!-- 675 - Brick by Stone Brick -->
	<!-- 676 - Brick by Brick -->
	<!-- 677 - Brick by Gold Brick -->
	<!ENTITY BrickFateIDs "216,660,661,666,667,668,669,670,671,672,673,674,675,676,677">
]>
<!-- End User Configuration -->
<Profile>
	<Name>Breaking Brick Mountains - Dragon Quest X Crossover</Name>
	<BehaviorDirectory></BehaviorDirectory>
	<KillRadius>90</KillRadius>
	<Order>

		<If Condition="GetQuestStep(66824) != 255 and &LowerLaNoscea; == 0 and &UpperLaNoscea; == 0 and &CentralShroud; == 0 and &NorthShroud; == 0 and &CentralThanalan; == 0">
			<UserDialog IsBotContinueAllowed="True" DialogText="You must open the profile and choose at least one zone to farm FATEs in." />
		</If>

		<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Checking for completed quest..." />

		<!-- Breaking Brick Mountains -->

		<If Condition="not IsQuestCompleted(66824)">
			<If Condition="not HasQuest(66824)">
				<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Picking up the Breaking Brick Mountains quest!" />
				<GetTo ZoneId="130" XYZ="47.37915, 4.099995, -148.4551" /> <!-- Havak Alvak -->
				<If Condition="IsQuestAcceptQualified(66824)">
					<PickupQuest NpcId="1005532" QuestId="66824" XYZ="47.37915, 4.099995, -148.4551" />
				</If>
			</If>
			<If Condition="HasQuest(66824)">
				<If Condition="GetQuestStep(66824) == 1">
					<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Talking to Beefy Businessman..." />
					<GetTo ZoneId="130" XYZ="-146.1357, 14.005, 56.13782" /> <!-- Beefy Businessman -->
					<TalkTo NpcId="1005533" XYZ="-146.1357, 14.005, 56.13782" QuestId="66824" StepId="1" />
				</If>

				<!-- Farm chunk of brickman in Lower La Noscea. -->

				<If Condition="&LowerLaNoscea;">
					<While Condition="GetQuestStep(66824) == 2">
						<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Obtaining a chunk of brickman..." />
						<GetTo ZoneId="135" XYZ="276.7286, 70.89819, -204.0882" />
						<LLFate FateId="&BrickFateIDs;" while="not IsTodoChecked(66824, 2, 0)" />
					</While>
				</If>

				<!-- Farm chunk of brickman in Upper La Noscea. -->

				<If Condition="&UpperLaNoscea;">
					<While Condition="GetQuestStep(66824) == 2">
						<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Obtaining a chunk of brickman..." />
						<GetTo ZoneId="139" XYZ="635.3461, -3.4, 135.6121" />
						<LLFate FateId="&BrickFateIDs;" while="not IsTodoChecked(66824, 2, 0)" />
					</While>
				</If>

				<!-- Farm chunk of brickman in Central Shroud. -->

				<If Condition="&CentralShroud;">
					<While Condition="GetQuestStep(66824) == 2">
						<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Obtaining a chunk of brickman..." />
						<GetTo ZoneId="148" XYZ="108.6752, -12, 121.7637" />
						<LLFate FateId="&BrickFateIDs;" while="not IsTodoChecked(66824, 2, 0)" />
					</While>
				</If>

				<!-- Farm chunk of brickman in North Shroud. -->

				<If Condition="&NorthShroud;">
					<While Condition="GetQuestStep(66824) == 2">
						<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Obtaining a chunk of brickman..." />
						<GetTo ZoneId="154" XYZ="-281.4612, -79.32581, 480.1272" />
						<LLFate FateId="&BrickFateIDs;" while="not IsTodoChecked(66824, 2, 0)" />
					</While>
				</If>

				<!-- Farm chunk of brickman in Central Thanalan. -->

				<If Condition="&CentralThanalan;">
					<While Condition="GetQuestStep(66824) == 2">
						<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Obtaining a chunk of brickman..." />
						<GetTo ZoneId="141" XYZ="-163.062, -30.94036, 100.6626" />
						<LLFate FateId="&BrickFateIDs;" while="not IsTodoChecked(66824, 2, 0)" />
					</While>
				</If>
				<If Condition="GetQuestStep(66824) == 255">
					<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="Turning in the Breaking Brick Mountains quest!" />
					<GetTo ZoneId="130" XYZ="-146.1357, 14.005, 56.13782" /> <!-- Beefy Businessman -->

					<!-- Rewards

					Wind-up Brickman
					Thug's Mug

					-->

					<TurnIn QuestId="66824" ItemId="2001166" NpcId="1005533" XYZ="-146.1357, 14.005, 56.13782" />
				</If>
			</If>
		</If>

		<Log Color="&LogColor;" Name="Breaking Brick Mountains" Message="You've completed Breaking Brick Mountains seasonal event quest!" />

	</Order>
	<CodeChunks>
	</CodeChunks>
	<GrindAreas>
	</GrindAreas>
</Profile>